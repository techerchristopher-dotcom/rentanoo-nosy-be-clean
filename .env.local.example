# Supabase Configuration
VITE_SUPABASE_URL=https://your-project-ref.supabase.co
VITE_SUPABASE_ANON_KEY=your-anon-key

# Backend Express (routes /api/*) — obligatoire pour l’admin en production si le SPA n’est pas servi
# par le même process que l’API. Sans slash final, et sans suffixe /api (les chemins ajoutent déjà /api/...).
# Local : laisser vide (Vite proxy /api → http://localhost:3000)
# Prod : ex. https://votre-service-api.up.railway.app
# VITE_API_URL=

# n8n Webhooks
# Webhook profiles-created (utilisé pour renvoyer l'email de confirmation)
VITE_N8N_PROFILES_CREATED_WEBHOOK_URL=https://n8n.srv1285649.hstgr.cloud/webhook/profiles-created

# Webhook welcome-client (email de bienvenue après vérification)
VITE_N8N_WELCOME_WEBHOOK_URL=https://n8n.srv1285649.hstgr.cloud/webhook/welcome-client

# Google Ads - Labels de conversion (récupérés dans Google Ads > Mesures > Conversions)
# Créer une action "Purchase" et une "Deposit", copier le label (ex: AbC1dEf2GhI3)
VITE_GOOGLE_ADS_CONVERSION_LABEL_PURCHASE=
VITE_GOOGLE_ADS_CONVERSION_LABEL_DEPOSIT=

# AeroDataBox via RapidAPI — horaires vols aéroport Nosy Be (NOS)
# Inscription gratuite : https://rapidapi.com/aedbx-aedbx/api/aerodatabox (600 unités/mois)
AERODATABOX_RAPIDAPI_KEY=
