                  <div className="space-y-2">
                    <div className="flex items-center justify-between">
                      <Label className={`text-sm font-medium ${isFieldMissing('Nombre de sièges') ? 'text-red-600' : 'text-slate-600'}`}>
                        {isFieldMissing('Nombre de sièges') && (
