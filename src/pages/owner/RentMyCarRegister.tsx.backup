                className={getFieldClasses('Email', 'h-12 text-base')}
              />
            </div>
            <div className="space-y-2">
              <Label className={`text-sm font-medium ${isFieldMissing('Téléphone') ? 'text-red-600' : 'text-slate-600'}`}>
                {isFieldMissing('Téléphone') && (
                  <AlertTriangle className="inline-block w-4 h-4 mr-1 mb-0.5" />
                )}
                Téléphone *
