              <Select value={formData.city} onValueChange={(value) => updateField('city', value)}>
                <SelectTrigger id="city" className={getFieldClasses('Ville', 'h-12 text-base')}>
                  <SelectValue placeholder="Sélectionner votre ville" />
                </SelectTrigger>
                <SelectContent>
                  {locations.map((location) => (
