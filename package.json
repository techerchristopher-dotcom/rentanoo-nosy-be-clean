{
  "name": "vite_react_shadcn_ts",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "engines": {
    "node": ">=20.0.0"
  },
  "scripts": {
    "dev": "vite",
    "dev:local": "concurrently -n api,vite -c blue,green \"cross-env PORT=3000 npm run dev:api\" \"npm run dev\"",
    "dev:renter": "vite --port 3000",
    "dev:tenant": "cross-env VITE_APP_CONTEXT=tenant vite --port 3012",
    "dev:owner": "cross-env VITE_APP_CONTEXT=owner vite --port 3013",
    "dev:3002": "vite --port 3002",
    "dev:3012": "vite --port 3012",
    "generate-sitemap": "node scripts/generate-sitemap.js",
    "prebuild": "npm run generate-sitemap",
    "build": "vite build",
    "build:dev": "vite build --mode development",
    "lint": "eslint .",
    "preview": "vite preview",
    "dev:api": "tsx server/index.ts",
    "start": "tsx server/index.ts",
    "start:prod": "NODE_ENV=production tsx server/index.ts",
    "diagnostic:duplication": "node scripts/diagnostic-duplication.js",
    "diagnose:stripe": "node scripts/diagnose-stripe-config.js",
    "verify:supabase": "node scripts/verify-supabase-connection.js",
    "switch:supabase": "./scripts/switch-supabase-project.sh",
    "i18n:extract": "i18next-scanner --config i18next-scanner.config.cjs",
    "i18n:codemod": "jscodeshift --parser=tsx -t codemods/i18n-transform.js",
    "i18n:codemod:dry-run": "jscodeshift --parser=tsx -t codemods/i18n-transform.js --dry --print",
    "i18n:codemod:pages": "jscodeshift --parser=tsx -t codemods/i18n-transform.js src/pages",
    "i18n:codemod:components": "jscodeshift --parser=tsx -t codemods/i18n-transform.js src/components",
    "test:unit": "tsx --test src/utils/rentalPriceFromDates.test.ts",
    "postbuild": "node scripts/generate-static-pages.js"
  },
